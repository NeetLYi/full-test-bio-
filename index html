// ═══════════════ TABS ═══════════════
function switchTab(tab) {
  document.getElementById("bankTab").classList.toggle("hidden", tab !== "bank");
  document.getElementById("startTab").classList.toggle("hidden", tab !== "start");
  document.getElementById("tabBank").classList.toggle("active", tab === "bank");
  document.getElementById("tabStart").classList.toggle("active", tab === "start");
  if (tab === "start") updateStartTab();
}

function updateStartTab() {
  const cnt = questions.length;
  const imgCnt = questions.filter(q => q.image).length;
  document.getElementById("startBankCount").textContent = cnt;
  document.getElementById("startImgCount").textContent = imgCnt;
}

// ═══════════════ QUESTION BANK ═══════════════
function refreshBankUI() {
  const list = document.getElementById("qList");
  document.getElementById("bankCount").textContent = `${questions.length} question${questions.length !== 1 ? "s" : ""}`;
  if (!questions.length) {
    list.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div><p>No questions yet. Click <strong>+ New Question</strong> to begin.</p></div>`;
    return;
  }
  list.innerHTML = "";
  questions.forEach((q, i) => {
    const row = document.createElement("div");
    row.className = "q-row" + (editingIndex === i ? " active-q" : "");
    row.onclick = () => openEditor(i);
    row.innerHTML = `
      <div class="q-row-num">Q${i+1}</div>
      <div class="q-row-body">
        <div class="q-row-text">${q.text}</div>
        <div class="q-row-meta">
          <span>${q.chapter || "No chapter"}</span>
          <span>${q.type || "mcq"}</span>
          ${q.image ? '<span class="img-badge">📷 image</span>' : ""}
        </div>
      </div>
    `;
    list.appendChild(row);
  });
}

// ═══════════════ EDITOR ═══════════════
function buildOptionsGrid(opts, correctIdx) {
  const grid = document.getElementById("optionsGrid");
  grid.innerHTML = "";
  const labels = ["A","B","C","D"];
  for (let i = 0; i < 4; i++) {
    const wrap = document.createElement("div");
    wrap.className = "opt-input-wrap";
    wrap.innerHTML = `
      <input type="radio" name="correctOpt" value="${i}" id="radio${i}"
        style="accent-color:var(--primary);cursor:pointer;"
        ${correctIdx === i ? "checked" : ""} />
      <span class="opt-label">${labels[i]}</span>
      <input type="text" id="opt${i}" placeholder="Option ${labels[i]}"
        value="${(opts && opts[i]) ? opts[i] : ""}" style="flex:1;" />
    `;
    grid.appendChild(wrap);
  }
}

function getSelectedAnswer() {
  const r = document.querySelector('input[name="correctOpt"]:checked');
  return r ? parseInt(r.value) : 0;
}

function newQuestion() {
  editingIndex = -1;
  showEditorFields();
  document.getElementById("eChapter").value = "";
  document.getElementById("eType").value = "mcq";
  document.getElementById("eText").value = "";
  document.getElementById("eStatements").value = "";
  document.getElementById("eAssertion").value = "";
  document.getElementById("eReason").value = "";
  document.getElementById("eExplanation").value = "";
  buildOptionsGrid(["","","",""], 0);
  clearImagePreview();
  onTypeChange();
  document.getElementById("deleteBtn").classList.add("hidden");
  refreshBankUI();
}

function openEditor(i) {
  editingIndex = i;
  const q = questions[i];
  showEditorFields();
  document.getElementById("eChapter").value = q.chapter || "";
  document.getElementById("eType").value = q.type || "mcq";
  document.getElementById("eText").value = q.text || "";
  document.getElementById("eStatements").value = q.statements ? q.statements.join("\n") : "";
  document.getElementById("eAssertion").value = q.assertion || "";
  document.getElementById("eReason").value = q.reason || "";
  document.getElementById("eExplanation").value = q.explanation || "";
  buildOptionsGrid(q.options, q.answer);
  if (q.image) setImagePreview(q.image);
  else clearImagePreview();
  onTypeChange();
  document.getElementById("deleteBtn").classList.remove("hidden");
  refreshBankUI();
}

function showEditorFields() {
  document.getElementById("editorEmpty").classList.add("hidden");
  document.getElementById("editorFields").classList.remove("hidden");
}

function clearEditor() {
  editingIndex = -1;
  document.getElementById("editorEmpty").classList.remove("hidden");
  document.getElementById("editorFields").classList.add("hidden");
  refreshBankUI();
}

function onTypeChange() {
  const t = document.getElementById("eType").value;
  document.getElementById("statementsBlock").classList.toggle("hidden", t !== "statements");
  document.getElementById("arBlock").classList.toggle("hidden", t !== "assertion-reason");
}

function saveQuestion() {
  const chapter = document.getElementById("eChapter").value.trim();
  const type = document.getElementById("eType").value;
  const text = document.getElementById("eText").value.trim();
  if (!text) { alert("Please enter a question stem."); return; }

  const opts = [0,1,2,3].map(i => document.getElementById(`opt${i}`).value.trim());
  if (opts.some(o => !o)) { alert("Please fill in all 4 options."); return; }

  const answer = getSelectedAnswer();

  const q = { chapter, type, text, options: opts, answer };

  q.explanation = document.getElementById("eExplanation").value.trim();

  if (type === "statements") {
    const lines = document.getElementById("eStatements").value.split("\n").map(s => s.trim()).filter(Boolean);
    q.statements = lines;
  }
  if (type === "assertion-reason") {
    q.assertion = document.getElementById("eAssertion").value.trim();
    q.reason = document.getElementById("eReason").value.trim();
  }

  const preview = document.getElementById("imgPreview");
  if (preview && preview.src && preview.src.startsWith("data:")) {
    q.image = preview.src; // base64 embedded!
  }

  if (editingIndex === -1) {
    questions.push(q);
    editingIndex = questions.length - 1;
  } else {
    questions[editingIndex] = q;
  }

  saveToStorage();
  document.getElementById("deleteBtn").classList.remove("hidden");
  refreshBankUI();
  showToast("Question saved ✓");
}

function deleteQuestion() {
  if (editingIndex === -1) return;
  if (!confirm("Delete this question?")) return;
  questions.splice(editingIndex, 1);
  saveToStorage();
  clearEditor();
  refreshBankUI();
}

// ═══════════════ IMAGE HANDLING ═══════════════
function onFileSelected(event) {
  const file = event.target.files[0];
  if (!file) return;
  loadImageFile(file);
}

function loadImageFile(file) {
  const reader = new FileReader();
  reader.onload = (e) => setImagePreview(e.target.result);
  reader.readAsDataURL(file);
}

function setImagePreview(base64) {
  const preview = document.getElementById("imgPreview");
  const wrap = document.getElementById("imgPreviewWrap");
  const prompt = document.getElementById("uploadPrompt");
  const removeBtn = document.getElementById("removeImgBtn");
  preview.src = base64;
  wrap.classList.remove("hidden");
  wrap.style.pointerEvents = "none";
  prompt.classList.add("hidden");
  removeBtn.style.display = "inline-block";
}

function clearImagePreview() {
  const preview = document.getElementById("imgPreview");
  const wrap = document.getElementById("imgPreviewWrap");
  const prompt = document.getElementById("uploadPrompt");
  const removeBtn = document.getElementById("removeImgBtn");
  preview.src = "";
  wrap.classList.add("hidden");
  prompt.classList.remove("hidden");
  removeBtn.style.display = "none";
  document.getElementById("imgFileInput").value = "";
}

function removeImage() {
  clearImagePreview();
}

function onDragOver(event) {
  event.preventDefault();
  document.getElementById("uploadZone").classList.add("drag-over");
}

function onDragLeave(event) {
  document.getElementById("uploadZone").classList.remove("drag-over");
}

function onDrop(event) {
  event.preventDefault();
  document.getElementById("uploadZone").classList.remove("drag-over");
  const file = event.dataTransfer.files[0];
  if (file && file.type.startsWith("image/")) loadImageFile(file);
}

// ═══════════════ IMPORT / EXPORT ═══════════════
function exportJSON() {
  const blob = new Blob([JSON.stringify(questions, null, 2)], { type: "application/json" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "neet_quiz_bank.json";
  a.click();
}

function importJSON() {
  document.getElementById("importFileInput").click();
}

function onImportFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const data = JSON.parse(e.target.result);
      if (!Array.isArray(data)) throw new Error("Expected an array");
      questions = data;
      saveToStorage();
      clearEditor();
      refreshBankUI();
      showToast(`Imported ${data.length} questions ✓`);
    } catch(err) {
      alert("Invalid JSON file: " + err.message);
    }
  };
  reader.readAsText(file);
  event.target.value = "";
}

// ═══════════════ QUIZ ═══════════════
function formatSec(s) {
  const m = Math.floor(s / 60).toString().padStart(2,"0");
  const sec = Math.floor(s % 60).toString().padStart(2,"0");
  return `${m}:${sec}`;
}

function startQuiz() {
  if (!questions.length) return;
  quizQuestions = [...questions];
  currentIndex = 0;
  selectedAnswers = Array(quizQuestions.length).fill(null);
  timeSpent = Array(quizQuestions.length).fill(0);
  visitedQuestions = Array(quizQuestions.length).fill(false);
  currentStatusFilter = "all";
  currentChapterFilter = "all";

  totalAllowedSeconds = Math.max(60, Math.min(10800, Number(document.getElementById("timerMinutes").value) * 60));
  remainingSeconds = totalAllowedSeconds;
  quizStartStamp = Date.now();
  questionEnterStamp = Date.now();

  document.getElementById("setup").classList.add("hidden");
  document.getElementById("results").classList.add("hidden");
  document.getElementById("quiz").classList.remove("hidden");

  if (countdownId) clearInterval(countdownId);
  countdownId = setInterval(() => {
    remainingSeconds--;
    const el = document.getElementById("remainingMeta");
    el.textContent = `⏱ ${formatSec(Math.max(0, remainingSeconds))}`;
    el.classList.toggle("warn", remainingSeconds <= 60);
    if (remainingSeconds <= 0) { clearInterval(countdownId); finishQuiz(); }
  }, 1000);

  renderQuestion();
}

function addCurrentQuestionTime() {
  if (!questionEnterStamp) return;
  const elapsed = Math.max(0, Math.floor((Date.now() - questionEnterStamp) / 1000));
  if (visitedQuestions[currentIndex]) timeSpent[currentIndex] += elapsed;
  questionEnterStamp = Date.now();
}

function goToQuestion(index) {
  if (index < 0 || index >= quizQuestions.length) return;
  addCurrentQuestionTime();
  currentIndex = index;
  renderQuestion();
}

function renderQuestion() {
  const q = quizQuestions[currentIndex];
  visitedQuestions[currentIndex] = true;
  document.getElementById("questionMeta").textContent = `Q ${currentIndex+1} / ${quizQuestions.length}`;
  document.getElementById("chapterMeta").textContent = q.chapter || "General";
  document.getElementById("questionText").textContent = q.text;

  // Extra (statements / assertion-reason)
  const extra = document.getElementById("questionExtra");
  extra.innerHTML = "";
  extra.classList.add("hidden");
  if (q.type === "statements" && q.statements?.length) {
    extra.innerHTML = q.statements.map(s => `<div class="question-extra-row">${s}</div>`).join("");
    extra.classList.remove("hidden");
  } else if (q.type === "assertion-reason" && q.assertion) {
    extra.innerHTML = `
      <div class="question-extra-row"><strong>Assertion:</strong> ${q.assertion}</div>
      <div class="question-extra-row"><strong>Reason:</strong> ${q.reason}</div>
    `;
    extra.classList.remove("hidden");
  }

  // Image — base64 or URL both work now
  const img = document.getElementById("questionImage");
  if (q.image) {
    img.src = q.image;
    img.classList.remove("hidden");
  } else {
    img.src = "";
    img.classList.add("hidden");
  }

  // Options
  const container = document.getElementById("options");
  container.innerHTML = "";
  q.options.forEach((opt, i) => {
    const btn = document.createElement("button");
    btn.className = "option-btn" + (selectedAnswers[currentIndex] === i ? " selected" : "");
    btn.textContent = `${["A","B","C","D"][i]}) ${opt}`;
    btn.onclick = () => {
      selectedAnswers[currentIndex] = i;
      renderQuestion();
      if (currentIndex < quizQuestions.length - 1) goToQuestion(currentIndex + 1);
    };
    container.appendChild(btn);
  });

  document.getElementById("prevBtn").disabled = currentIndex === 0;
  document.getElementById("nextBtn").disabled = currentIndex === quizQuestions.length - 1;
  document.getElementById("remainingMeta").textContent = `⏱ ${formatSec(Math.max(0, remainingSeconds))}`;
}

function evaluateStatus(idx) {
  const a = selectedAnswers[idx];
  if (a === null) return "skipped";
  return a === quizQuestions[idx].answer ? "correct" : "incorrect";
}

function finishQuiz() {
  addCurrentQuestionTime();
  if (countdownId) clearInterval(countdownId);
  quizEndStamp = Date.now();
  document.getElementById("quiz").classList.add("hidden");
  document.getElementById("results").classList.remove("hidden");
  renderResults();
}

// ═══════════════ RESULTS ═══════════════
function renderResults() {
  const statuses = quizQuestions.map((_,i) => evaluateStatus(i));
  const correct = statuses.filter(s=>s==="correct").length;
  const incorrect = statuses.filter(s=>s==="incorrect").length;
  const skipped = statuses.filter(s=>s==="skipped").length;
  const totalSec = Math.max(1, Math.round((quizEndStamp - quizStartStamp) / 1000));

  document.getElementById("summaryGrid").innerHTML = `
    <div class="summary-item">Total<strong>${quizQuestions.length}</strong></div>
    <div class="summary-item">Correct<strong class="good">${correct}</strong></div>
    <div class="summary-item">Incorrect<strong class="bad">${incorrect}</strong></div>
    <div class="summary-item">Skipped<strong class="skip">${skipped}</strong></div>
    <div class="summary-item">Time<strong>${formatSec(totalSec)}</strong></div>
  `;

  renderStatusFilters(correct, incorrect, skipped);
  renderChapterFilters();
  renderChapterSummary();
  renderAnswerPie(correct, incorrect, skipped);
  renderReviewList();
  renderTimeBars();
}

function renderStatusFilters(c,i,s) {
  document.getElementById("statusFilters").innerHTML = "";
  [["all","All"],["correct",`Correct (${c})`],["incorrect",`Incorrect (${i})`],["skipped",`Skipped (${s})`]].forEach(([k,l]) => {
    const btn = document.createElement("button");
    btn.className = "filter-chip" + (currentStatusFilter===k ? " active-chip" : "");
    btn.textContent = l;
    btn.onclick = () => { currentStatusFilter=k; renderResults(); };
    document.getElementById("statusFilters").appendChild(btn);
  });
}

function renderChapterFilters() {
  const chapters = [...new Set(quizQuestions.map(q=>q.chapter))];
  const el = document.getElementById("chapterFilters");
  el.innerHTML = "";
  ["all", ...chapters].forEach(ch => {
    const btn = document.createElement("button");
    btn.className = "filter-chip";
    btn.textContent = ch === "all" ? "All Chapters" : ch;
    if (ch !== "all") {
      const idxs = quizQuestions.map((q,i)=>({q,i})).filter(x=>x.q.chapter===ch).map(x=>x.i);
      const pct = (idxs.filter(i=>evaluateStatus(i)==="correct").length / idxs.length) * 100;
      btn.classList.add(pct>=70?"chapter-high":pct>=50?"chapter-mid":"chapter-low");
    }
    if (currentChapterFilter===ch) btn.classList.add("active-chip");
    btn.onclick = () => { currentChapterFilter=ch; renderResults(); };
    el.appendChild(btn);
  });
}

function renderAnswerPie(c,i,s) {
  const attempted = c+i;
  const angle = attempted ? Math.max(0, Math.min(360,(c/attempted)*360)) : 0;
  document.getElementById("answerPie").style.background =
    `conic-gradient(#15803d 0deg ${angle}deg, #b91c1c ${angle}deg 360deg)`;
  document.getElementById("pieLegend").innerHTML = `
    <div class="legend-item"><span class="legend-dot" style="background:#15803d"></span>Correct: <strong>${c}</strong></div>
    <div class="legend-item"><span class="legend-dot" style="background:#b91c1c"></span>Incorrect: <strong>${i}</strong></div>
    <div class="legend-item muted">Attempted: ${attempted} / ${quizQuestions.length}${s?" (Skipped: "+s+")":""}</div>
  `;
}

function renderChapterSummary() {
  const chapters = [...new Set(quizQuestions.map(q=>q.chapter))];
  document.getElementById("chapterSummaryList").innerHTML = chapters.map(ch => {
    const idxs = quizQuestions.map((q,i)=>({q,i})).filter(x=>x.q.chapter===ch).map(x=>x.i);
    const c=idxs.filter(i=>evaluateStatus(i)==="correct").length;
    const inc=idxs.filter(i=>evaluateStatus(i)==="incorrect").length;
    const sk=idxs.filter(i=>evaluateStatus(i)==="skipped").length;
    return `<div class="chapter-summary-item"><strong>${ch}</strong><br>
      <span class="good">✓ ${c}</span> &nbsp;
      <span class="bad">✗ ${inc}</span> &nbsp;
      <span class="skip">— ${sk}</span></div>`;
  }).join("");
}

function renderReviewList() {
  const el = document.getElementById("reviewList");
  el.innerHTML = "";
  let found = 0;
  quizQuestions.forEach((q,idx) => {
    const status = evaluateStatus(idx);
    if (currentStatusFilter !== "all" && status !== currentStatusFilter) return;
    if (currentChapterFilter !== "all" && q.chapter !== currentChapterFilter) return;
    found++;
    const ua = selectedAnswers[idx];
    const cssClass = status==="correct"?"good":status==="incorrect"?"bad":"skip";
    const node = document.createElement("div");
    node.className = "review-item";
    node.innerHTML = `
      <div class="q-stem">Q${idx+1} <span class="muted">(${q.chapter})</span> — ${q.text}</div>
      ${q.image ? `<img src="${q.image}" class="review-img" alt="Q image" />` : ""}
      <div class="${cssClass}">Status: ${status}</div>
      <div>Your answer: ${ua!==null ? q.options[ua] : "—"}</div>
      <div>Correct: <span class="good">${q.options[q.answer]}</span></div>
      <div class="muted" style="margin-top:2px;">Time: ${formatSec(timeSpent[idx])}</div>
      ${q.explanation ? `<div class="explanation-box"><span class="explanation-label">💡 Explanation</span>${q.explanation}</div>` : ""}
    `;
    el.appendChild(node);
  });
  if (!found) {
    el.innerHTML = `<div class="review-item muted">No questions match this filter.</div>`;
  }
}

function renderTimeBars() {
  const el = document.getElementById("barChart");
  el.innerHTML = "";
  const maxSec = Math.max(1, ...timeSpent);
  quizQuestions.forEach((q,idx) => {
    const w = Math.max(4, (timeSpent[idx]/maxSec)*100);
    const node = document.createElement("div");
    node.className = "bar-card";
    node.innerHTML = `
      <div class="bar-top"><div>Q${idx+1} (${q.chapter})</div><div>${formatSec(timeSpent[idx])}</div></div>
      <div class="bar-bg"><div class="bar-fill" style="width:${w}%"></div></div>
    `;
    el.appendChild(node);
  });
}

function restartToSetup() {
  document.getElementById("results").classList.add("hidden");
  document.getElementById("setup").classList.remove("hidden");
  updateStartTab();
}

// ═══════════════ TOAST ═══════════════
function showToast(msg) {
  let t = document.getElementById("toast");
  if (!t) {
    t = document.createElement("div");
    t.id = "toast";
    t.style.cssText = "position:fixed;bottom:24px;right:24px;background:#1e3a8a;border:1px solid #3b82f6;color:#dbeafe;padding:10px 18px;border-radius:10px;font-size:14px;font-family:'DM Sans',sans-serif;z-index:9999;transition:opacity 0.3s;";
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = "1";
  clearTimeout(t._timeout);
  t._timeout = setTimeout(() => { t.style.opacity = "0"; }, 2200);
}

// ═══════════════ INIT ═══════════════
// Sync timer number input and slider
(function() {
  const num = document.getElementById("timerMinutes");
  const slider = document.getElementById("timerSlider");
  const display = document.getElementById("timerDisplay");
  function fmt(m) {
    return String(m).padStart(2,"0") + ":00";
  }
  function sync(val) {
    val = Math.max(1, Math.min(180, val));
    num.value = val;
    slider.value = val;
    display.textContent = fmt(val);
  }
  num.addEventListener("input", () => sync(parseInt(num.value) || 1));
  slider.addEventListener("input", () => sync(parseInt(slider.value)));
})();

updateStartTab();
</script>
