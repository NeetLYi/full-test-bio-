<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NEET Quiz</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0b1120;
      --card: #111827;
      --card2: #0f172a;
      --primary: #3b82f6;
      --primary-soft: #1e3a8a;
      --text: #e5e7eb;
      --muted: #9ca3af;
      --good: #22c55e;
      --bad: #f87171;
      --skip: #f59e0b;
      --border: #334155;
      --accent: #818cf8;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    .container {
      width: min(960px, 94vw);
      margin: 28px auto 60px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 22px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    }

    h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 6px; }
    h2 { font-size: 1.3rem; font-weight: 600; margin-bottom: 14px; }
    h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 10px; }

    .muted { color: var(--muted); font-size: 14px; }
    .hidden { display: none !important; }

    /* ── TABS ── */
    .tab-row {
      display: flex;
      gap: 6px;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 10px;
    }

    .tab-btn {
      padding: 8px 16px;
      border-radius: 8px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--muted);
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      transition: all 0.18s;
    }

    .tab-btn.active {
      background: var(--primary-soft);
      border-color: var(--primary);
      color: #dbeafe;
      font-weight: 600;
    }

    .tab-btn:hover:not(.active) { color: var(--text); border-color: var(--border); }

    /* ── BUTTONS ── */
    button {
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: all 0.18s;
    }

    .btn {
      padding: 10px 16px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: #1f2937;
      color: var(--text);
      font-size: 14px;
    }

    .btn:hover:not(:disabled) { background: #273548; border-color: #4b6080; }
    .btn:active:not(:disabled) { transform: translateY(1px); }
    .btn.primary { background: var(--primary); border-color: var(--primary); color: #fff; font-weight: 600; }
    .btn.primary:hover:not(:disabled) { background: #2563eb; }
    .btn.danger { background: #7f1d1d; border-color: #991b1b; color: #fca5a5; }
    .btn.danger:hover { background: #991b1b; }
    .btn.success { background: #14532d; border-color: #166534; color: #86efac; }
    .btn.success:hover { background: #166534; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }

    /* ── SETUP ── */
    .setup-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin: 16px 0;
    }

    @media (max-width: 600px) { .setup-grid { grid-template-columns: 1fr; } }

    .setup-stat {
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px;
    }

    .setup-stat .label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .setup-stat .val { font-size: 1.5rem; font-weight: 700; margin-top: 4px; }

    .setup-row {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin: 14px 0;
    }

    select {
      padding: 10px 12px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: #1f2937;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
    }

    /* ── QUESTION BANK EDITOR ── */
    .bank-toolbar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 16px;
      align-items: center;
    }

    .q-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 16px;
      max-height: 340px;
      overflow-y: auto;
    }

    .q-list::-webkit-scrollbar { width: 6px; }
    .q-list::-webkit-scrollbar-track { background: var(--card2); border-radius: 4px; }
    .q-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .q-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .q-row:hover { border-color: #4b6080; }
    .q-row.active-q { border-color: var(--primary); background: #0f1f3d; }

    .q-row-num {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--accent);
      min-width: 28px;
      padding-top: 2px;
    }

    .q-row-body { flex: 1; min-width: 0; }
    .q-row-text { font-size: 13px; line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .q-row-meta { font-size: 11px; color: var(--muted); margin-top: 3px; display: flex; gap: 8px; }

    .img-badge {
      background: #1e3a5f;
      color: #7dd3fc;
      border-radius: 4px;
      padding: 1px 6px;
      font-size: 10px;
      font-weight: 600;
    }

    /* ── QUESTION EDITOR FORM ── */
    .editor-form {
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 18px;
    }

    .form-row { margin-bottom: 14px; }

    .form-label {
      display: block;
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    input[type="text"], textarea, select.full {
      width: 100%;
      padding: 10px 12px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: #0b1120;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      line-height: 1.5;
      transition: border-color 0.18s;
    }

    input[type="text"]:focus, textarea:focus, select.full:focus {
      outline: none;
      border-color: var(--primary);
    }

    textarea { resize: vertical; min-height: 70px; }

    .options-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    @media (max-width: 520px) { .options-grid { grid-template-columns: 1fr; } }

    .opt-input-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .opt-label {
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      color: var(--accent);
      min-width: 20px;
    }

    /* ── IMAGE UPLOAD ZONE ── */
    .upload-zone {
      border: 2px dashed var(--border);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: #0b1120;
      position: relative;
    }

    .upload-zone:hover, .upload-zone.drag-over {
      border-color: var(--primary);
      background: #0f1f3d;
    }

    .upload-zone input[type="file"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }

    .upload-icon { font-size: 2rem; margin-bottom: 8px; }
    .upload-hint { font-size: 13px; color: var(--muted); }

    .img-preview-wrap {
      margin-top: 10px;
      position: relative;
      display: inline-block;
    }

    .img-preview {
      max-width: 100%;
      max-height: 200px;
      border-radius: 10px;
      border: 1px solid var(--border);
      display: block;
    }

    .img-remove-btn {
      position: absolute;
      top: 6px;
      right: 6px;
      background: rgba(0,0,0,0.7);
      border: 1px solid #f87171;
      color: #f87171;
      border-radius: 6px;
      padding: 4px 8px;
      font-size: 12px;
      cursor: pointer;
    }

    .img-remove-btn:hover { background: #7f1d1d; }

    .editor-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
    }

    /* ── QUIZ ── */
    .top-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .pill {
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid var(--border);
      font-size: 13px;
      background: #1f2937;
    }

    .pill.timer { font-family: 'DM Mono', monospace; font-weight: 600; }
    .pill.timer.warn { border-color: #f59e0b; color: #f59e0b; }

    .question-img {
      width: 100%;
      max-height: 260px;
      object-fit: contain;
      border-radius: 10px;
      border: 1px solid var(--border);
      margin-bottom: 14px;
      background: #0f172a;
    }

    .question-text { font-size: 1.05rem; line-height: 1.6; margin-bottom: 4px; }

    .question-extra {
      margin: 10px 0;
      border: 1px solid var(--border);
      background: #0f172a;
      border-radius: 10px;
      padding: 12px;
      font-size: 14px;
      line-height: 1.5;
    }

    .question-extra-row { margin: 4px 0; }
    .question-extra-row strong { color: #bfdbfe; }

    .options { display: grid; gap: 10px; margin-top: 14px; }

    .option-btn {
      text-align: left;
      width: 100%;
      padding: 13px 15px;
      border: 1px solid var(--border);
      border-radius: 11px;
      background: #1f2937;
      color: var(--text);
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      transition: all 0.15s;
    }

    .option-btn:hover { background: #253449; border-color: #5b7ba8; box-shadow: 0 0 0 3px rgba(59,130,246,0.12); transform: translateY(-1px); }
    .option-btn.selected { border-color: var(--primary); background: var(--primary-soft); box-shadow: 0 0 0 3px rgba(59,130,246,0.2); }

    .nav-row {
      margin-top: 16px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    /* ── RESULTS ── */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 10px;
      margin: 14px 0;
    }

    .summary-item {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px;
      background: #1f2937;
      font-size: 14px;
    }

    .summary-item strong { display: block; font-size: 1.4rem; margin-top: 4px; }

    .filters { display: flex; gap: 8px; flex-wrap: wrap; margin: 10px 0 16px; }

    .filter-chip {
      padding: 7px 13px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: #1f2937;
      color: var(--text);
      font-size: 13px;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      transition: all 0.15s;
    }

    .filter-chip:hover { border-color: #4b6080; }
    .filter-chip.active-chip { border-color: var(--primary); background: var(--primary-soft); color: #dbeafe; font-weight: 600; }
    .chapter-high { background: #15803d; border-color: #166534; color: #fff; }
    .chapter-mid { background: #ca8a04; border-color: #a16207; color: #fff; }
    .chapter-low { background: #b91c1c; border-color: #991b1b; color: #fff; }

    .answer-pie-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      align-items: center;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      background: #1f2937;
      margin-bottom: 14px;
    }

    .answer-pie {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      border: 1px solid var(--border);
      position: relative;
      flex-shrink: 0;
    }

    .answer-pie::after {
      content: "";
      position: absolute;
      width: 68px;
      height: 68px;
      border-radius: 50%;
      background: #1f2937;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .pie-legend { display: grid; gap: 10px; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 14px; }
    .legend-dot { width: 12px; height: 12px; border-radius: 999px; display: inline-block; }

    .chapter-summary-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 8px;
      margin-bottom: 14px;
    }

    .chapter-summary-item {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px;
      background: #1f2937;
      font-size: 13px;
    }

    .review-list {
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      background: #1f2937;
      margin-top: 10px;
    }

    .review-item {
      padding: 13px;
      border-bottom: 1px solid var(--border);
      font-size: 14px;
      line-height: 1.5;
    }

    .review-item:last-child { border-bottom: none; }
    .review-item .q-stem { font-weight: 500; margin-bottom: 6px; }

    .explanation-box {
      margin-top: 10px;
      background: #0f2744;
      border: 1px solid #1e40af;
      border-left: 3px solid #3b82f6;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 13px;
      line-height: 1.6;
      color: #bfdbfe;
    }

    .explanation-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #60a5fa;
      margin-bottom: 5px;
    }

    .review-img {
      max-height: 140px;
      border-radius: 8px;
      border: 1px solid var(--border);
      margin: 6px 0;
      display: block;
    }

    .good { color: var(--good); font-weight: 600; }
    .bad { color: var(--bad); font-weight: 600; }
    .skip { color: var(--skip); font-weight: 600; }

    .bar-wrap {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px;
      margin-top: 14px;
      background: #1f2937;
    }

    .bar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
      margin-top: 10px;
    }

    .bar-card { border: 1px solid var(--border); border-radius: 10px; padding: 10px; background: #0f172a; }
    .bar-top { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 8px; }
    .bar-bg { width: 100%; background: #1e293b; border-radius: 999px; height: 8px; overflow: hidden; }
    .bar-fill { background: #60a5fa; height: 100%; border-radius: 999px; }

    .empty-state {
      text-align: center;
      padding: 40px 20px;
      color: var(--muted);
    }

    .empty-icon { font-size: 3rem; margin-bottom: 10px; }
    .empty-state p { font-size: 14px; }

    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 20px 0;
    }

    .correct-ans-badge {
      display: inline-block;
      background: #14532d;
      border: 1px solid #166534;
      color: #86efac;
      border-radius: 6px;
      padding: 2px 8px;
      font-size: 12px;
      margin-left: 6px;
    }
  </style>
</head>
<body>
<div class="container">

  <!-- ═══════════════ SETUP ═══════════════ -->
  <section id="setup" class="card">
    <h1>NEET Practice Quiz</h1>
    <p class="muted" style="margin-bottom:24px;">10 questions · Biology · Select your timer and begin</p>

    <div style="margin-bottom:20px;">
      <div class="setup-grid">
        <div class="setup-stat">
          <div class="label">Questions</div>
          <div class="val" id="startBankCount">0</div>
        </div>
        <div class="setup-stat">
          <div class="label">With Images</div>
          <div class="val" id="startImgCount">0</div>
        </div>
      </div>
    </div>

    <div style="margin-bottom:24px;">
      <label class="form-label" style="display:block;margin-bottom:10px;">Set Timer (1 – 180 minutes)</label>
      <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
        <input type="number" id="timerMinutes" min="1" max="180" value="15"
          style="width:90px;padding:10px 12px;border-radius:9px;border:1px solid var(--border);
                 background:#0b1120;color:var(--text);font-family:'DM Sans',sans-serif;
                 font-size:1.1rem;font-weight:600;text-align:center;" />
        <span class="muted">minutes</span>
        <input type="range" id="timerSlider" min="1" max="180" value="15"
          style="flex:1;min-width:120px;accent-color:var(--primary);cursor:pointer;" />
        <span id="timerDisplay"
          style="font-family:'DM Mono',monospace;font-size:1rem;color:#60a5fa;min-width:52px;text-align:right;font-weight:600;">
          15:00
        </span>
      </div>
    </div>

    <button class="btn primary" style="width:100%;padding:14px;font-size:1rem;letter-spacing:0.02em;" onclick="startQuiz()">▶ Start Quiz</button>
  </section>

  <!-- ═══════════════ QUIZ ═══════════════ -->
  <section id="quiz" class="card hidden" style="margin-top:16px;">
    <div class="top-line">
      <div class="pill" id="questionMeta">Q 1 / 10</div>
      <div class="pill" id="chapterMeta">Chapter</div>
      <div class="pill timer" id="remainingMeta">00:00</div>
    </div>

    <p class="question-text" id="questionText"></p>
    <div id="questionExtra" class="question-extra hidden"></div>
    <img id="questionImage" class="question-img hidden" alt="Question image" />
    <div id="options" class="options"></div>

    <div class="nav-row">
      <button class="btn" id="prevBtn" onclick="goToQuestion(currentIndex-1)">← Prev</button>
      <div style="display:flex;gap:8px;">
        <button class="btn" id="nextBtn" onclick="goToQuestion(currentIndex+1)">Next →</button>
        <button class="btn primary" onclick="finishQuiz()">Submit Quiz</button>
      </div>
    </div>
  </section>

  <!-- ═══════════════ RESULTS ═══════════════ -->
  <section id="results" class="card hidden" style="margin-top:16px;">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:14px;">
      <h2 style="margin:0;">Results</h2>
      <button class="btn" onclick="restartToSetup()">← Back to Bank</button>
    </div>

    <div class="summary-grid" id="summaryGrid"></div>

    <div class="answer-pie-wrap">
      <div id="answerPie" class="answer-pie"></div>
      <div id="pieLegend" class="pie-legend"></div>
    </div>

    <hr class="section-divider">
    <h3>Filter by Status</h3>
    <div class="filters" id="statusFilters"></div>

    <h3>Filter by Chapter</h3>
    <div class="filters" id="chapterFilters"></div>

    <h3>Chapter Accuracy</h3>
    <div id="chapterSummaryList" class="chapter-summary-list"></div>

    <h3>Question Review</h3>
    <div class="review-list" id="reviewList"></div>

    <div class="bar-wrap">
      <h3 style="margin-bottom:0;">Time Per Question</h3>
      <div id="barChart" class="bar-grid"></div>
    </div>
  </section>

</div>


<script>
// ═══════════════ STATE ═══════════════
let questions = loadFromStorage();
let editingIndex = -1;
let currentAnswerRadio = -1;

// Quiz state
let currentIndex = 0;
let selectedAnswers = [];
let timeSpent = [];
let visitedQuestions = [];
let questionEnterStamp = 0;
let quizStartStamp = 0;
let quizEndStamp = 0;
let totalAllowedSeconds = 0;
let remainingSeconds = 0;
let countdownId = null;
let currentStatusFilter = "all";
let currentChapterFilter = "all";
let quizQuestions = [];

// ═══════════════ STORAGE ═══════════════
const BANK_VERSION = "v3";

function saveToStorage() {
  try {
    localStorage.setItem("neet_quiz_bank", JSON.stringify(questions));
    localStorage.setItem("neet_quiz_bank_version", BANK_VERSION);
  } catch(e) {}
}

function loadFromStorage() {
  try {
    const version = localStorage.getItem("neet_quiz_bank_version");
    if (version !== BANK_VERSION) {
      localStorage.removeItem("neet_quiz_bank");
      localStorage.removeItem("neet_quiz_bank_version");
      return getDefaultQuestions();
    }
    const d = localStorage.getItem("neet_quiz_bank");
    return d ? JSON.parse(d) : getDefaultQuestions();
  } catch(e) { return getDefaultQuestions(); }
}

function getDefaultQuestions() {
  const GINKGO = "data:image/png;base64,";
  return [
    {
      chapter: "Biological Classification",
      text: "Which of the following organisms are characterized by the presence of a rigid cell wall?",
      options: ["Chrysophytes", "Archaebacteria", "Eubacteria", "Slime Moulds"],
      answer: 2, type: "mcq",
      explanation: "The Eubacteria are characterized by the presence of a rigid cell wall. NCERT page 13, under the Eubacteria section."
    },
    {
      chapter: "Biological Classification",
      text: "Which of the following regarding the Basidiomycetes is correct?",
      options: [
        "They are also known as the perfect fungi",
        "Morels and truffles are included under Basidiomycetes",
        "The sexual organs are present in Basidiomycetes",
        "The spores are produced exogenously"
      ],
      answer: 3, type: "mcq",
      explanation: "The spores in Basidiomycetes are produced exogenously on the basidium — not endogenously. Basidiomycetes are not called perfect fungi (that term applies to Ascomycetes). Morels and truffles belong to Ascomycetes. Sexual organs are absent in Basidiomycetes — karyogamy and meiosis occur directly in the basidium."
    },
    {
      chapter: "Biological Classification",
      text: "Creutzfeldt-Jakob disease is caused by which of the following acellular organisms?",
